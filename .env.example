# Copy this file to .env and fill in your values

# ── Telegram Bot ──────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Polymarket Auto-Trading (optional) ───────────────────────
# Your Polymarket wallet private key (hex, no 0x prefix)
# ONLY needed if you want auto-trading
POLYMARKET_PRIVATE_KEY=

# Polymarket API credentials (from polymarket.com/settings)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
